# === AI provider — mặc định LOCAL MIỄN PHÍ, đa ngôn ngữ (hỗ trợ tiếng Việt) ===
EMBED_PROVIDER=fastembed
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBED_DIM=384
# LLM: none = không gọi LLM (trả đoạn truy hồi) | ollama | openai
LLM_PROVIDER=none
LLM_MODEL=gpt-4o-mini
# Chỉ cần khi LLM_PROVIDER=openai (hoặc EMBED_PROVIDER=openai):
OPENAI_API_KEY=sk-thay-bang-khoa-cua-ban
# Chỉ cần khi LLM_PROVIDER=ollama:
OLLAMA_HOST=http://localhost:11434

# === Hạ tầng (khớp docker-compose) ===
POSTGRES_URL=postgresql://rag:rag@localhost:5432/rag
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_chunks

# === Tham số RAG ===
CACHE_TTL=3600
EMBED_CACHE_TTL=604800
CHUNK_MAX_TOKENS=400
CHUNK_OVERLAP=80
RETRIEVE_TOP_K=5
HISTORY_TURNS=6

# === Auth / bảo mật (BẮT BUỘC đổi JWT_SECRET, tối thiểu 32 ký tự) ===
JWT_SECRET=doi-secret-nay-toi-thieu-32-ky-tu-ngau-nhien
ACCESS_TOKEN_TTL_MIN=720
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_SEC=60
